From 48715d4bf7e7a8bbfcd4ea879e7e04360cd983ae Mon Sep 17 00:00:00 2001
From: Andreas Beckmann <anbe@debian.org>
Date: Wed, 28 Jan 2026 15:40:39 +0100
Subject: [PATCH 2/4] support fallback for for_each_*_plane_in_state

---
 nvidia-drm/nvidia-drm-helper.c  |  2 +-
 nvidia-drm/nvidia-drm-helper.h  | 18 ++++++++++++++++++
 nvidia-drm/nvidia-drm-modeset.c |  4 ++--
 3 files changed, 21 insertions(+), 3 deletions(-)

diff --git a/nvidia-drm/nvidia-drm-helper.c b/nvidia-drm/nvidia-drm-helper.c
index 8c828da7..88ecac70 100644
--- a/nvidia-drm/nvidia-drm-helper.c
+++ b/nvidia-drm/nvidia-drm-helper.c
@@ -154,7 +154,7 @@ int nv_drm_atomic_helper_disable_all(struct drm_device *dev,
             goto free;
     }
 
-    for_each_new_plane_in_state(state, plane, plane_state, i) {
+    nv_drm_for_each_new_plane_in_state(state, plane, plane_state, i) {
         ret = drm_atomic_set_crtc_for_plane(plane_state, NULL);
         if (ret < 0)
             goto free;
diff --git a/nvidia-drm/nvidia-drm-helper.h b/nvidia-drm/nvidia-drm-helper.h
index 1ce4fba8..c686a3a1 100644
--- a/nvidia-drm/nvidia-drm-helper.h
+++ b/nvidia-drm/nvidia-drm-helper.h
@@ -211,6 +211,11 @@ int nv_drm_atomic_helper_disable_all(struct drm_device *dev,
  * points to the new state, while afterwards it points to the old state. Due to
  * this tricky confusion this macro is deprecated.
  */
+#if defined(for_each_new_connector_in_state)
+#define nv_drm_for_each_connector_in_state(__state,                         \
+                                           connector, connector_state, __i) \
+    for_each_new_connector_in_state(__state, connector, connector_state, __i)
+#else
 #if !defined(for_each_connector_in_state)
 #define nv_drm_for_each_connector_in_state(__state,                         \
                                            connector, connector_state, __i) \
@@ -225,6 +230,7 @@ int nv_drm_atomic_helper_disable_all(struct drm_device *dev,
                                            connector, connector_state, __i) \
     for_each_connector_in_state(__state, connector, connector_state, __i)
 #endif
+#endif
 
 
 /**
@@ -277,6 +283,18 @@ int nv_drm_atomic_helper_disable_all(struct drm_device *dev,
     for_each_plane_in_state(__state, plane, plane_state, __i)
 #endif
 
+#if defined(for_each_new_plane_in_state)
+#define nv_drm_for_each_new_plane_in_state for_each_new_plane_in_state
+#else
+#define nv_drm_for_each_new_plane_in_state nv_drm_for_each_plane_in_state
+#endif
+
+#if defined(for_each_old_plane_in_state)
+#define nv_drm_for_each_old_plane_in_state for_each_old_plane_in_state
+#else
+#define nv_drm_for_each_old_plane_in_state nv_drm_for_each_plane_in_state
+#endif
+
 static inline struct drm_crtc *nv_drm_crtc_find(struct drm_device *dev,
     uint32_t id)
 {
diff --git a/nvidia-drm/nvidia-drm-modeset.c b/nvidia-drm/nvidia-drm-modeset.c
index c1bb34d8..e98607f6 100644
--- a/nvidia-drm/nvidia-drm-modeset.c
+++ b/nvidia-drm/nvidia-drm-modeset.c
@@ -109,7 +109,7 @@ static bool __will_generate_flip_event(struct drm_crtc *crtc,
      * Find out whether primary & overlay flip done events will be generated.
      * Only called after drm_atomic_helper_swap_state, so we use old state.
      */
-    for_each_old_plane_in_state(old_crtc_state->state,
+    nv_drm_for_each_old_plane_in_state(old_crtc_state->state,
         plane, old_plane_state, i) {
         if (old_plane_state->crtc != crtc) {
            continue;
@@ -191,7 +191,7 @@ static int __nv_drm_get_syncpt_data(
     head_reply_config = &reply_config->headReplyConfig[nv_crtc->head];
 
     /* Use old state because this is only called after drm_atomic_helper_swap_state */
-    for_each_old_plane_in_state(old_crtc_state->state, plane, old_plane_state, i) {
+    nv_drm_for_each_old_plane_in_state(old_crtc_state->state, plane, old_plane_state, i) {
 
         if (plane->type == DRM_PLANE_TYPE_CURSOR || old_plane_state->crtc != crtc) {
             continue;
-- 
2.39.5

