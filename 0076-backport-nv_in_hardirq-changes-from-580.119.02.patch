From 99ab934ea6c41b1adda5a5aa1c1f45f2ebcfb990 Mon Sep 17 00:00:00 2001
From: Andreas Beckmann <anbe@debian.org>
Date: Tue, 27 Jan 2026 18:09:15 +0100
Subject: [PATCH] backport nv_in_hardirq changes from 580.119.02

---
 common/inc/nv-time.h  | 17 +++++++++++++++--
 nvidia/os-interface.c |  2 +-
 2 files changed, 16 insertions(+), 3 deletions(-)

diff --git a/common/inc/nv-time.h b/common/inc/nv-time.h
index 01333830..ba44e5a1 100644
--- a/common/inc/nv-time.h
+++ b/common/inc/nv-time.h
@@ -42,6 +42,19 @@ struct timespec64 {
 };
 #endif
 
+/*
+ * in_hardirq() was added in v5.11-rc1 (2020-12-15) to replace in_irq().
+ * Fall back to in_irq() for older kernels that don't have in_hardirq().
+ */
+static inline NvBool nv_in_hardirq(void)
+{
+#if defined(in_hardirq)
+    return in_hardirq();
+#else
+    return in_irq();
+#endif
+}
+
 #if !defined(NV_KTIME_GET_RAW_TS64_PRESENT)
 static inline void ktime_get_raw_ts64(struct timespec64 *ts64)
 {
@@ -141,7 +154,7 @@ static inline NV_STATUS nv_sleep_us(unsigned int us)
     ktime_get_real_ts64(&tm1);
 #endif
 
-    if (in_irq() && (us > NV_MAX_ISR_DELAY_US))
+    if (nv_in_hardirq() && (us > NV_MAX_ISR_DELAY_US))
         return NV_ERR_GENERIC;
 
     mdelay_safe_msec = us / 1000;
@@ -187,7 +200,7 @@ static inline NV_STATUS nv_sleep_ms(unsigned int ms)
     tm_start = tm_aux;
 #endif
 
-    if (in_irq() && (ms > NV_MAX_ISR_DELAY_MS))
+    if (nv_in_hardirq() && (ms > NV_MAX_ISR_DELAY_MS))
     {
         return NV_ERR_GENERIC;
     }
diff --git a/nvidia/os-interface.c b/nvidia/os-interface.c
index 1efbbfa7..91911b62 100644
--- a/nvidia/os-interface.c
+++ b/nvidia/os-interface.c
@@ -229,7 +229,7 @@ NvBool NV_API_CALL os_semaphore_may_sleep(void)
 
 NvBool NV_API_CALL os_is_isr(void)
 {
-    return (in_irq());
+    return (nv_in_hardirq());
 }
 
 // return TRUE if the caller is the super-user
-- 
2.39.5

